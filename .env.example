# Transactional email for the trial-request form (send-only key is fine).
# Same Resend account as farmboard — from-address uses the verified farmboard.app domain.
RESEND_API_KEY=

# Where trial requests are delivered.
TRIAL_REQUEST_TO=joe@productdetroit.com

# Where tophand.ag/login redirects — the app's hostname.
# Set to https://app.tophand.ag once that domain is attached to the farmboard
# Vercel project; until then the default (https://farmboard.app) applies.
APP_URL=
